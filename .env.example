PORT=3000

# Cloudlog base URL. Both of these forms work:
# https://cloudlog.example.com
# https://cloudlog.example.com/index.php
CLOUDLOG_BASE_URL=https://cloudlog.example.com
CLOUDLOG_API_KEY=replace-with-your-read-write-api-key
CLOUDLOG_LOGBOOK_PUBLIC_SLUG=replace-with-your-public-logbook-slug

# Optional. If omitted, the app tries to use the active station profile.
CLOUDLOG_STATION_PROFILE_ID=

# Contest defaults
DEFAULT_MODE=SSB
DEFAULT_RST_SENT=59
DEFAULT_RST_RCVD=59
SERIAL_START=1
SERIAL_PAD=3
BANDS=160m,80m,40m,20m,15m,10m

# Callsign lookup provider:
# - hamdb: free, no auth, partial worldwide coverage
# - none: disable external lookup and only use Cloudlog duplicate check
CALLSIGN_LOOKUP_PROVIDER=hamdb
