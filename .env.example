PORT=3000

# Cloudlog base URL. Both of these forms work:
# https://cloudlog.example.com
# https://cloudlog.example.com/index.php
CLOUDLOG_BASE_URL=https://cloudlog.example.com
CLOUDLOG_API_KEY=replace-with-your-read-write-api-key
CLOUDLOG_LOGBOOK_PUBLIC_SLUG=replace-with-your-public-logbook-slug

# Optional. If omitted, the app tries to use the active station profile.
CLOUDLOG_STATION_PROFILE_ID=

# Contest defaults
DEFAULT_MODE=AM
DEFAULT_OPERATOR_CALLSIGN=
DEFAULT_RST_SENT=59
DEFAULT_RST_RCVD=59
OPERATORS=
SERIAL_START=1
SERIAL_PAD=3
BANDS=160m,80m,40m,20m,15m,10m

# Local backup log file, written after every successful QSO upload
BACKUP_LOG_FILE=data/qso-backup.ndjson

# Callsign lookups always try HamDB and QRZ together.
# QRZ is optional; if credentials are missing or invalid, the app keeps using HamDB.

# QRZ XML interface credentials
QRZ_USERNAME=
QRZ_PASSWORD=
QRZ_AGENT=qso_constest/0.1.0
